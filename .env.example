# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_PROVIDER=sqlite          # sqlite | postgres
DATABASE_URL=Data Source=fitness.db
# For Supabase / Render Postgres, use the full connection string:
# DATABASE_URL=postgresql://user:password@host:5432/postgres

# ── AI Provider ──────────────────────────────────────────────────────────────
# Replace these three values to switch AI providers. No other changes needed.
#
# DeepSeek:
#   AI_API_KEY=your-deepseek-api-key
#   AI_BASE_URL=https://api.deepseek.com
#   AI_MODEL=deepseek-v4-flash
#
# Azure AI Foundry (auto-detected from the services.ai.azure.com URL):
#   AI_API_KEY=your-azure-api-key
#   AI_BASE_URL=https://your-resource.services.ai.azure.com/models
#   AI_MODEL=DeepSeek-V4-Flash
#
AI_API_KEY=your-api-key
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-flash

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_ORIGINS=http://localhost:5173
# Multiple origins (comma-separated):
# FRONTEND_ORIGINS=https://www.example.com,https://example.com,http://localhost:5173

# ── Cloudflare Tunnel (optional) ─────────────────────────────────────────────
# CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token
